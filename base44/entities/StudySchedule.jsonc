{
  "name": "StudySchedule",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "generated_by_ai": {
      "type": "boolean",
      "default": true
    },
    "completed": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
